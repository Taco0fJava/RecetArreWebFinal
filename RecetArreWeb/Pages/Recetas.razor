@page "/recetas"
@attribute [Authorize]
@inject IRecetaService recetaService
@inject ICategoriaService categoriaService
@inject NavigationManager navigation
@inject IJSRuntime JSRuntime

<PageTitle>El Recetario de la Abuela | Cocina Creativa</PageTitle>

<style>
    
    :root {
        --sage-green: #84a98c;
        --deep-sage: #52796f;
        --cream: #fdfcf0;
        --warm-white: #fffcf2;
        --terracotta: #b56576;
        --wheat: #e9c46a;
        --wood-brown: #6d597a;
        --text-dark: #354f52;
        --shadow-rustic: 0 6px 15px rgba(53, 79, 82, 0.1);
        --radius-organic: 24px 12px 24px 12px;
    }

    .recipe-container {
        background-color: var(--cream);
        background-image: radial-gradient(var(--sage-green) 0.5px, transparent 0.5px);
        background-size: 30px 30px; /* Sutil patrón de puntos rústico */
        min-height: 100vh;
        font-family: 'Open Sans', sans-serif;
        color: var(--text-dark);
    }

    /* Estilo del Encabezado */
    .hero-section {
        background: var(--deep-sage);
        border: 3px double var(--wheat);
        border-radius: var(--radius-organic);
        padding: 3rem;
        margin-bottom: 2.5rem;
        color: var(--warm-white);
        text-align: center;
        position: relative;
        box-shadow: var(--shadow-rustic);
    }

    .hero-title {
        font-family: 'Open Sans', sans-serif;
        font-style: italic;
        font-size: 3rem;
        margin-bottom: 0.5rem;
    }

    .btn-cottage {
        background: var(--terracotta);
        border: 2px solid rgba(255,255,255,0.2);
        color: white;
        padding: 0.8rem 2rem;
        border-radius: 40px;
        font-weight: 500;
        transition: all 0.3s ease;
        box-shadow: 0 4px 0px #8e4453;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-cottage:hover {
        transform: translateY(2px);
        box-shadow: 0 2px 0px #8e4453;
        background: #9d5262;
        color: white;
    }

    /* Tarjeta de Búsqueda */
    .search-card {
        background: var(--warm-white);
        border-radius: 15px;
        padding: 2rem;
        box-shadow: var(--shadow-rustic);
        border: 1px dashed var(--sage-green);
        margin-bottom: 3rem;
    }

    .form-control-cottage {
        border: 1px solid var(--sage-green);
        border-radius: 10px;
        padding: 0.75rem 1rem;
        background: #fff;
        font-family: 'Open Sans', sans-serif;
    }

    .form-control-cottage:focus {
        outline: none;
        border-color: var(--terracotta);
        box-shadow: 0 0 0 3px rgba(181, 101, 118, 0.1);
    }

    /* Tarjetas de Receta */
    .recipe-card {
        background: var(--warm-white);
        border-radius: var(--radius-organic);
        overflow: hidden;
        box-shadow: var(--shadow-rustic);
        transition: transform 0.3s ease;
        border: 1px solid rgba(132, 169, 140, 0.2);
        height: 100%;
    }

    .recipe-card:hover {
        transform: scale(1.02);
    }

    .recipe-image-container {
        height: 180px;
        background: #e9ecef;
        position: relative;
        border-bottom: 2px dashed var(--sage-green);
    }

    .recipe-image-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--sage-green);
        font-size: 3rem;
        background-color: #f1f3f0;
    }

    .recipe-badge {
        position: absolute;
        top: 1rem;
        left: 1rem;
        padding: 0.3rem 0.8rem;
        border-radius: 5px;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .badge-published { background: var(--sage-green); color: white; }
    .badge-draft { background: var(--wood-brown); color: white; }

    .recipe-content { padding: 1.5rem; }

    .recipe-title {
        font-family: 'Open Sans', sans-serif;
        font-weight: 700;
        color: var(--text-dark);
        font-size: 1.4rem;
    }

    .meta-icon { color: var(--terracotta); }

    .btn-view {
        background: var(--sage-green);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        width: 100%;
        margin-bottom: 0.5rem;
    }

    .btn-action-icon {
        background: transparent;
        border: 1px solid var(--sage-green);
        color: var(--sage-green);
        border-radius: 8px;
        width: 38px;
        height: 38px;
        transition: all 0.2s;
    }

    .btn-action-icon:hover {
        background: var(--sage-green);
        color: white;
    }

    .btn-delete:hover {
        background: var(--terracotta);
        border-color: var(--terracotta);
    }

    /* Alertas */
    .alert-cottage {
        border-radius: 12px;
        border: 2px dashed currentColor;
        background: var(--warm-white);
        font-weight: 500;
    }

    .loading-container {
        text-align: center;
        padding: 5rem;
        color: var(--deep-sage);
    }

    .spinner-cottage {
        border: 4px solid var(--cream);
        border-top: 4px solid var(--terracotta);
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1.5s linear infinite;
        margin: 0 auto 1rem;
    }

    @@keyframes spin { 100% { transform: rotate(360deg); } }

</style>

<div class="recipe-container">
    <div class="container py-5">
        
        <div class="hero-section">
            <h1 class="hero-title">Mis Recetas de Campo</h1>
            <p style="font-size: 1.2rem; opacity: 0.9;">Un espacio para tus tesoros culinarios y aromas de hogar</p>
            <div class="mt-4">
                <button type="button" class="btn-cottage" @onclick="IrACrear">
                    <i class="bi bi-flower1"></i> Crear Nueva Receta
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(mensajeExito))
        {
            <div class="alert alert-cottage text-success mb-4" role="alert">
                <i class="bi bi-stars me-2"></i> @mensajeExito
            </div>
        }
        
        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div class="alert alert-cottage text-danger mb-4" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i> @mensajeError
            </div>
        }

        <div class="search-card">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-5">
                    <label class="form-label small fw-bold">Buscar en el herbolario:</label>
                    <input type="text" class="form-control-cottage w-100" placeholder="Ej: Pastel de moras..." @bind="busqueda" @bind:event="oninput" />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label small fw-bold">Categoría:</label>
                    <select class="form-control-cottage w-100" @bind="categoriaFiltro">
                        <option value="0">Todas las estaciones</option>
                        @if (categorias != null)
                        {
                            @foreach (var cat in categorias)
                            {
                                <option value="@cat.Id">@cat.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-12 col-md-3">
                    <button type="button" class="btn btn-outline-dark w-100" @onclick="LimpiarFiltros" style="border-radius:10px; padding: 0.7rem;">
                        <i class="bi bi-arrow-counterclockwise"></i> Reiniciar
                    </button>
                </div>
            </div>
        </div>

        <div class="row g-4">
            @if (recetas == null)
            {
                <div class="col-12">
                    <div class="loading-container">
                        <div class="spinner-cottage"></div>
                        <p>Batiendo los ingredientes...</p>
                    </div>
                </div>
            }
            else if (!RecetasFiltradas.Any())
            {
                <div class="col-12 text-center py-5">
                    <div style="font-size: 4rem;">🧺</div>
                    <h3 class="mt-3">Aún no hay recetas aquí</h3>
                    <p class="text-muted">Parece que tu delantal está esperando ser estrenado.</p>
                </div>
            }
            else
            {
                @foreach (var receta in RecetasFiltradas)
                {
                    <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                        <div class="recipe-card">
                            <div class="recipe-image-container">
                                <div class="recipe-image-placeholder">
                                    <i class="bi bi-egg-fried"></i>
                                </div>
                                <span class="recipe-badge @(receta.EstaPublicado ? "badge-published" : "badge-draft")">
                                    @(receta.EstaPublicado ? "En la mesa" : "Cocinándose")
                                </span>
                            </div>

                            <div class="recipe-content">
                                <h5 class="recipe-title">@receta.Titulo</h5>
                                <p class="text-muted small" style="height: 3rem; overflow: hidden;">
                                    @(string.IsNullOrEmpty(receta.Descripcion) ? "Una receta secreta..." : receta.Descripcion)
                                </p>

                                <div class="d-flex gap-3 mb-3 small">
                                    <span><i class="bi bi-hourglass-split meta-icon"></i> @(receta.TiempoPreparacionMinutos + receta.TiempoCoccionMinutos) min</span>
                                    <span><i class="bi bi-house-heart meta-icon"></i> @receta.Porciones porc.</span>
                                </div>

                                <div class="pt-3 border-top">
                                    <button class="btn-view" @onclick="() => IrADetalle(receta.Id)">Leer Receta</button>
                                    <div class="d-flex gap-2">
                                        <button class="btn-action-icon flex-grow-1" @onclick="() => IrAEditar(receta.Id)"><i class="bi bi-pencil-square"></i></button>
                                        <button class="btn-action-icon btn-delete flex-grow-1" @onclick="() => EliminarReceta(receta.Id)"><i class="bi bi-trash3"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    // ... (El bloque @code se mantiene exactamente igual al que proporcionaste)
    private List<RecetaDto>? recetas;
    private List<CategoriaDto>? categorias;
    private string busqueda = "";
    private int categoriaFiltro = 0;
    private string mensajeExito = string.Empty;
    private string mensajeError = string.Empty;

    private IEnumerable<RecetaDto> RecetasFiltradas
    {
        get
        {
            if (recetas == null) return Enumerable.Empty<RecetaDto>();
            var resultado = recetas.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(busqueda))
            {
                resultado = resultado.Where(r =>
                    r.Titulo.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ||
                    (r.Descripcion?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false));
            }
            if (categoriaFiltro > 0)
            {
                resultado = resultado.Where(r => r.CategoriaIds.Contains(categoriaFiltro));
            }
            return resultado;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var tareaRecetas = recetaService.ObtenerTodas();
        var tareaCategorias = categoriaService.ObtenerTodas();
        await Task.WhenAll(tareaRecetas, tareaCategorias);
        recetas = tareaRecetas.Result;
        categorias = tareaCategorias.Result;
    }

    private async Task EliminarReceta(int id)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "¿Deseas borrar esta receta de tu libro personal?"))
            return;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;
        var resultado = await recetaService.Eliminar(id);
        if (resultado)
        {
            mensajeExito = "¡La receta ha vuelto a la tierra!";
            recetas = await recetaService.ObtenerTodas();
        }
        else
        {
            mensajeError = "No se pudo retirar la receta.";
        }
    }

    private void IrACrear() => navigation.NavigateTo("/recetas/crear");
    private void IrADetalle(int id) => navigation.NavigateTo($"/recetas/{id}");
    private void IrAEditar(int id) => navigation.NavigateTo($"/recetas/editar/{id}");
    private void LimpiarFiltros() { busqueda = ""; categoriaFiltro = 0; }
}