@page "/medallas"
@attribute [Authorize]
@inject IMedallaService medallaService

<PageTitle>Mis Medallas | RecetArre</PageTitle>

<div class="cc-page">
    <div class="cc-hero">
        <div class="container">
            <h1 class="cc-hero-title">🏅 Mis Medallas</h1>
            <p class="cc-hero-sub">Tus logros culinarios conquistados</p>
        </div>
    </div>

    <div class="container">
        @if (cargando)
        {
            <div class="cc-loading">
                <div class="spinner-border cc-spinner mb-3" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
                <p class="mb-0">Buscando tus logros...</p>
            </div>
        }
        else
        {
            <div class="row mb-3">
                <div class="col-12">
                    <div class="cc-stats-bar">
                        <span class="cc-stat">
                            <strong>@medallasVista.Count(m => m.Obtenida)</strong> de <strong>@medallasVista.Count</strong> medallas obtenidas
                        </span>
                        <div class="cc-progress-wrap">
                            <div class="cc-progress-bar"
                                 style="width: @(medallasVista.Count > 0 ? (medallasVista.Count(m => m.Obtenida) * 100 / medallasVista.Count) : 0)%">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                @foreach (var medalla in medallasVista)
                {
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <div class="cc-medal-card @(medalla.Obtenida ? "obtenida" : "bloqueada")">
                            <div class="cc-medal-icon">@medalla.Icono</div>
                            <div class="cc-medal-nombre">@medalla.Nombre</div>
                            <div class="cc-medal-desc">@medalla.Descripcion</div>
                            @if (medalla.Obtenida && medalla.FechaObtencion.HasValue)
                            {
                                <div class="cc-medal-fecha">
                                    ✅ @medalla.FechaObtencion.Value.ToLocalTime().ToString("dd MMM yyyy")
                                </div>
                            }
                            else if (!medalla.Obtenida)
                            {
                                <div class="cc-medal-lock">🔒 Pendiente</div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .cc-page {
        min-height: 100vh;
        padding-bottom: 3rem;
        font-family: 'Open Sans', sans-serif;
        color: #3a2e22;
    }

    .cc-hero {
        background: linear-gradient(135deg, #1e3a2f 0%, #2d5a46 100%);
        border-radius: 0 0 24px 24px;
        padding: 2.2rem 0 2rem;
        margin-bottom: 2rem;
    }

    .cc-hero-title {
        font-family: 'Open Sans', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        color: #e8d5b0;
        margin-bottom: 4px;
    }

    .cc-hero-sub {
        font-size: 0.9rem;
        color: rgba(245, 240, 232, 0.65);
        font-style: italic;
        margin: 0;
    }

    .cc-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        background: #faf6ee;
        border-radius: 14px;
        border: 1.5px solid #c8b898;
        color: #8a7a68;
        font-style: italic;
    }
    .cc-spinner { color: #5a7a4a; }

    .cc-stats-bar {
        background: #faf6ee;
        border: 1.5px solid #c8b898;
        border-radius: 12px;
        padding: 14px 20px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 0.5rem;
    }
    .cc-stat { font-size: 0.9rem; color: #3a2e22; }
    .cc-progress-wrap {
        background: #ede6d6;
        border-radius: 8px;
        height: 8px;
        overflow: hidden;
    }
    .cc-progress-bar {
        background: linear-gradient(90deg, #5a7a4a, #8aab7a);
        height: 100%;
        border-radius: 8px;
        transition: width 0.8s ease;
    }

    .cc-medal-card {
        background: #faf6ee;
        border: 1.5px solid #c8b898;
        border-radius: 16px;
        padding: 1.5rem 1rem;
        text-align: center;
        transition: transform 0.2s, box-shadow 0.2s;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }
    .cc-medal-card.obtenida {
        border-color: #8aab7a;
        background: linear-gradient(135deg, #f0f7ec, #faf6ee);
        box-shadow: 0 4px 16px rgba(90, 122, 74, 0.15);
    }
    .cc-medal-card.obtenida:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(90, 122, 74, 0.22);
    }
    .cc-medal-card.bloqueada {
        opacity: 0.5;
        filter: grayscale(0.7);
    }
    .cc-medal-icon { font-size: 2.8rem; line-height: 1; }
    .cc-medal-nombre {
        font-size: 0.95rem;
        font-weight: 700;
        color: #3a2e22;
    }
    .cc-medal-desc {
        font-size: 0.82rem;
        color: #8a7a68;
        font-style: italic;
    }
    .cc-medal-fecha { font-size: 0.75rem; color: #5a7a4a; font-weight: 600; }
    .cc-medal-lock  { font-size: 0.78rem; color: #a0906e; font-style: italic; }
</style>

@code {
    // Definiciones locales — siempre se muestran aunque la API falle
    private static readonly List<MedallaInfoDto> DefinicionesLocales = new()
    {
        new() { Tipo = "bienvenido",           Icono = "🌱", Nombre = "¡Bienvenido!",            Descripcion = "Te uniste a la comunidad RecetArre" },
        new() { Tipo = "primer_comentario",    Icono = "🗨️", Nombre = "Primer Comentario",        Descripcion = "Dejaste tu primer comentario" },
        new() { Tipo = "chef_debut",           Icono = "🍳", Nombre = "Chef Debut",               Descripcion = "Publicaste tu primera receta" },
        new() { Tipo = "primer_voto",          Icono = "⭐", Nombre = "Primer Voto",              Descripcion = "Calificaste tu primera receta" },
        new() { Tipo = "comentarista_activo",  Icono = "💬", Nombre = "Comentarista Activo",      Descripcion = "Comentaste 10 veces" },
        new() { Tipo = "chef_prolifico",       Icono = "👨‍🍳", Nombre = "Chef Prolífico",           Descripcion = "Publicaste 5 recetas" },
        new() { Tipo = "catador_sabores",      Icono = "🌟", Nombre = "Catador de Sabores",       Descripcion = "Calificaste 5 recetas" },
        new() { Tipo = "comentarista_experto", Icono = "🏅", Nombre = "Comentarista Experto",     Descripcion = "Comentaste 50 veces" },
        new() { Tipo = "chef_legendario",      Icono = "👑", Nombre = "Chef Legendario",          Descripcion = "Publicaste 10 recetas" },
        new() { Tipo = "explorador_sabores",   Icono = "🌠", Nombre = "Explorador Gastronómico",  Descripcion = "Calificaste 25 recetas" },
    };

    private List<MedallaInfoDto> medallasVista = new();
    private bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        // Partir siempre de las 10 definiciones locales (todas bloqueadas)
        medallasVista = DefinicionesLocales
            .Select(d => new MedallaInfoDto
            {
                Tipo = d.Tipo, Icono = d.Icono,
                Nombre = d.Nombre, Descripcion = d.Descripcion,
                Obtenida = false, FechaObtencion = null
            }).ToList();

        // Intentar obtener cuáles están ganadas desde la API
        try
        {
            var ganadas = await medallaService.ObtenerMisMedallas();
            if (ganadas.Count > 0)
            {
                // Combinar: actualizar Obtenida/FechaObtencion para las que la API reporta
                foreach (var m in medallasVista)
                {
                    var apiMedalla = ganadas.FirstOrDefault(g => g.Tipo == m.Tipo);
                    if (apiMedalla != null && apiMedalla.Obtenida)
                    {
                        m.Obtenida = true;
                        m.FechaObtencion = apiMedalla.FechaObtencion;
                    }
                }
            }
        }
        catch { /* si la API falla, se muestran todas bloqueadas */ }

        cargando = false;
    }
}
